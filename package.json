{
  "name": "zero-vue",
  "type": "module",
  "version": "0.8.1",
  "packageManager": "pnpm@11.5.2",
  "description": "",
  "license": "MIT",
  "repository": "danielroe/zero-vue",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "vitest dev",
    "lint": "eslint .",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test",
    "test": "pnpm test:unit && pnpm test:types && pnpm test:e2e",
    "test:e2e": "pnpm -r --workspace-concurrency=1 test:e2e",
    "test:unit": "vitest",
    "test:types": "tsc --noEmit && pnpm -r test:types"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@rocicorp/zero": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "latest",
    "@rocicorp/resolver": "1.0.2",
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "installed-check": "latest",
    "knip": "latest",
    "nano-staged": "1.0.2",
    "simple-git-hooks": "latest",
    "tsdown": "0.22.2",
    "typescript": "latest",
    "vitest": "latest",
    "vue": "3.5.35",
    "zod": "4.4.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,.*rc}": [
      "npx eslint --fix"
    ]
  }
}
