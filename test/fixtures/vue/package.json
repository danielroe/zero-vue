{
  "name": "zero-vue-fixture-vue",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "preview": "vite preview",
    "dev:ui": "vite dev",
    "dev:zero-cache": "cd ../_shared && zero-cache-dev -p db/schema.ts",
    "dev:db-up": "cd ../_shared && docker compose --env-file .env -f docker/docker-compose.yml up",
    "dev:db-down": "cd ../_shared && docker compose --env-file .env -f docker/docker-compose.yml down",
    "dev:clean": "cd ../_shared && source .env && docker compose --env-file .env -f docker/docker-compose.yml down -v && rm -rf \"${ZERO_REPLICA_FILE}\"*",
    "test:types": "vue-tsc --build"
  },
  "dependencies": {
    "@vueuse/integrations": "^14.3.0",
    "h3": "^1.15.11",
    "jose": "^6.2.3",
    "postgres": "3.4.7",
    "universal-cookie": "^8.1.2",
    "vue": "^3.5.34",
    "zero-vue": "link:",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/js-cookie": "3.0.6",
    "@types/node": "24.11.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vue-tsc": "3.3.6"
  }
}
